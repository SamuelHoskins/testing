# PostgreSQL connection string provided by Supabase
DATABASE_URL="postgresql://postgres:postgres@db.supabase.co:5432/postgres?schema=public"
# Optional direct connection string for migrations (Supabase provides this in project settings)
DIRECT_URL="postgresql://postgres:postgres@db.supabase.co:5432/postgres?schema=public"

# Supabase Auth configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Prisma specific (used when running migrations locally)
PRISMA_HIDE_UPDATE_MESSAGE="true"
